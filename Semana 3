--vemos los libros--
SELECT * FROM Libros;

--vemos solo el titulo y precio--
SELECT titulo, precio FROM Libros;

--libros que cuestan mas de 20 (where)--
SELECT titulo, precio
FROM Libros
WHERE precio > 20;

--ordenamos libros por precio (mayora menor)--
SELECT titulo, precio
FROM Libros
ORDER BY precio DESC;

--mostramos el titulo del libro y el nombre del autor (inner join)--
SELECT Libros.titulo, Autores.nombre
FROM Libros
INNER JOIN Autores
ON Libros.id_autor = Autores.id_autor;

--libros de autores de colombia, ordenados por precio--
SELECT Libros.titulo, Autores.nombre, Libros.precio
FROM Libros
INNER JOIN Autores
ON Libros.id_autor = Autores.id_autor
WHERE Autores.pais = 'Colombia'
ORDER BY Libros.precio ASC;
